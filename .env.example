# Flask Environment Configuration
# Local development
FLASK_ENV=development
FLASK_DEBUG=1

# Application Secret Keys
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# Local MySQL example
DATABASE_URL=mysql+pymysql://root:@localhost:3306/nha_sach_gang_thep?charset=utf8mb4

# Railway options:
# 1. Recommended: create DATABASE_URL on the web service and set it to:
#    ${{MySQL.MYSQL_URL}}
# 2. Or let the app read Railway's MYSQL_URL / MYSQLHOST / MYSQLPORT / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE automatically.

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRES=3600

# Force secure cookies outside local development if needed
# SESSION_COOKIE_SECURE=true

# Rate Limiting (optional)
# For Redis-based rate limiting (uncomment if using Redis):
# REDIS_URL=redis://localhost:6379/0

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=uploads

# Email Configuration (if implementing email features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

